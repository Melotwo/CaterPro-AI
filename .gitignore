.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf and dependency
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Output directory (Vite build output)
dist/
dist-ssr/

# Firebase cache / local logs
.firebase/
firestore-debug.log
ui-debug.log

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

