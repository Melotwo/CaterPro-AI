rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: menus
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - userId: string (required, immutable)
    //   - baseGuestCount: number (required)
    //   - currentGuestCount: number (required)
    //   - cuisine: string
    //   - budget: string
    //   - description: string
    //   - appetizers: list
    //   - mainCourses: list
    //   - sideDishes: list
    //   - dessert: list
    //   - ingredients: list of maps
    //   - labor: map
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: ingredientCosts
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - cost: number (required)
    //   - unit: string (required)
    //   - category: string
    //   - userId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidNumber(val, min, max) {
      return val is number && val >= min && val <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidMenu(data) {
      return data.keys().hasAll(['title', 'userId', 'baseGuestCount', 'currentGuestCount']) &&
             isValidString(data.title, 1, 200) &&
             data.userId is string &&
             isValidNumber(data.baseGuestCount, 1, 10000) &&
             isValidNumber(data.currentGuestCount, 1, 10000);
    }

    function isValidIngredientCost(data) {
      return data.keys().hasAll(['name', 'cost', 'unit', 'userId']) &&
             isValidString(data.name, 1, 100) &&
             isValidNumber(data.cost, 0, 1000000) &&
             isValidString(data.unit, 1, 20) &&
             data.userId is string;
    }

